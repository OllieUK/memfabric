MEMGRAPH_HOST=localhost
MEMGRAPH_PORT=7687
MEMGRAPH_USER=
MEMGRAPH_PASSWORD=
API_HOST=0.0.0.0
API_PORT=8000
EMBEDDING_MODEL=all-MiniLM-L6-v2
# Primary switch for offline embedding mode. When true (default), the embeddings module
# passes local_files_only=True to SentenceTransformer, preventing any model downloads.
# Set to false only for a one-time initial download (requires internet access).
# NOTE: Do NOT set HF_HUB_OFFLINE or TRANSFORMERS_OFFLINE — transformers>=4.50 calls
# model_info() inside AutoTokenizer even for locally-cached models, and those env vars
# turn that into a hard error. EMBEDDING_LOCAL_FILES_ONLY=true is the correct guard.
EMBEDDING_LOCAL_FILES_ONLY=true

# Pre-load the embedding model at API startup rather than on first request.
# Keeps first-request latency predictable. Disable (0) to speed up cold starts in testing.
EMBEDDING_PRELOAD_ON_STARTUP=1

# Enables uvicorn --reload for development. Set to 0 in production or when running as a service.
MEMORY_SERVICE_RELOAD=1
AGENT_ID=claude-code

# memory_client settings
API_BASE_URL=https://memfabric.carr-it.net:8443

# Reinforcement / decay (WP-029)
MEMORY_DECAY_RATE=0.01

# WP-048: Two-speed decay + importance floor
# Multiplier on (importance/5) for initial memory strength (default: 0.4)
# INITIAL_STRENGTH_FACTOR=0.4

# Fast decay rate applied to new memories before first reinforcement (default: 0.07, ~10-day half-life)
# MEMORY_INITIAL_DECAY_RATE=0.07

# Slow decay rate after first reinforcement / consolidation (default: 0.01, ~69-day half-life)
# MEMORY_CONSOLIDATED_DECAY_RATE=0.01

# Multiplier on (importance/5) for per-node min_strength floor (default: 0.3)
# importance=5 → floor=0.3; importance=1 → floor=0.06
# IMPORTANCE_FLOOR_FACTOR=0.3
EDGE_DECAY_RATE=0.005
RECALL_STRENGTH_INCREMENT=0.05
EXPLICIT_STRENGTH_INCREMENT=0.20
EDGE_RECALL_INCREMENT=0.02
EDGE_EXPLICIT_INCREMENT=0.10
EDGE_PRUNE_THRESHOLD=0.05
MIN_MEMORY_STRENGTH=0.0

# Maintenance orchestration (WP-040)
SHORT_REST_RECENCY_DAYS=7
LONG_REST_RECENCY_DAYS=1
REDISCOVERY_STRENGTH_THRESHOLD=0.3
EDGE_HARD_PRUNE_FLOOR=0.01
EDGE_HARD_PRUNE_MIN_DAYS=90
EDGE_MODULATION_FACTOR=0.5
EDGE_MODULATION_CAP=10.0
# Max neighbours returned per traversal direction in search results (RELATED_TO, causes, effects).
# Total neighbours per hit is bounded by 3 × SEARCH_NEIGHBOUR_CAP.
SEARCH_NEIGHBOUR_CAP=50

# --- Knowledge layer (ADR-001 / WP-094) ---
# Feature flag — knowledge routes only load when true (default: false)
ENABLE_KNOWLEDGE_LAYER=false
# Independent embedding model for knowledge-layer vector indexes.
# Decouples knowledge migration timeline from episodic memory (EMBEDDING_MODEL).
KNOWLEDGE_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# --- Document ingestion pipeline (WP-073) ---
# Max characters per PDF chunk (default: 2000)
# INGEST_CHUNK_SIZE=2000
# Character overlap between adjacent PDF chunks (default: 200)
# INGEST_CHUNK_OVERLAP=200
# Minimum chunk length; shorter chunks are skipped (default: 50)
# INGEST_MIN_CHUNK_CHARS=50
# Enable auto-SUPPORTS inference after ingestion (default: false — safe off)
INGEST_AUTO_SUPPORTS=false
# Cosine distance threshold for auto-SUPPORTS (default: 0.20 — conservative)
# INGEST_AUTO_SUPPORTS_THRESHOLD=0.20
# Review mode: print candidates but create no SUPPORTS edges (default: true — safe on)
INGEST_CHUNK_REVIEW_MODE=true

# --- Knowledge layer index capacities (WP-069) ---
# MEMORY_INDEX_CAPACITY=5000
# FRAMEWORK_INDEX_CAPACITY=5000
# CHUNK_INDEX_CAPACITY=10000

# Authentication (WP-096)
# Comma-separated list of valid bearer tokens / API keys.
# Empty = service runs unauthenticated (dev / localhost mode).
API_KEYS=your-secret-token-here

# OAuth / MCP discovery (WP-169): public base URL for RFC 9728 protected-resource metadata.
# The `resource` field in the discovery document is constructed as <PUBLIC_BASE_URL>/mcp/
# Production value: https://memfabric.carr-it.net
# Local dev default (matches API_PORT): http://localhost:8000
# PUBLIC_BASE_URL=http://localhost:8000